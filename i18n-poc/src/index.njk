---
pagination:
  data: locales
  size: 1
  alias: loc
permalink: "{% if loc.isDefault %}index.html{% else %}{{ loc.code }}/index.html{% endif %}"
---
<!DOCTYPE html>
<html lang="{{ loc.code }}" dir="{{ loc.dir }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ loc.t.meta.title }}</title>
  <meta name="description" content="{{ loc.t.meta.description }}" />
  <meta name="theme-color" content="#7a3a1d" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Canonical + hreflang alternates, generated per locale from the locales data -->
  <link rel="canonical" href="{{ site.url }}{% if not loc.isDefault %}/{{ loc.code }}{% endif %}/" />
  {%- for l in locales %}
  <link rel="alternate" hreflang="{{ l.code }}" href="{{ site.url }}{% if not l.isDefault %}/{{ l.code }}{% endif %}/" />
  {%- endfor %}
  <link rel="alternate" hreflang="x-default" href="{{ site.url }}/" />

  <!-- Open Graph -->
  <meta property="og:title" content="{{ loc.t.meta.ogTitle }}" />
  <meta property="og:description" content="{{ loc.t.meta.ogDescription }}" />
  <meta property="og:url" content="{{ site.url }}{% if not loc.isDefault %}/{{ loc.code }}{% endif %}/" />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="{{ loc.ogLocale }}" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ loc.t.meta.ogTitle }}" />
  <meta name="twitter:description" content="{{ loc.t.meta.ogDescription }}" />

  <!-- Newsreader, served from Bunny Fonts (EU-hosted, GDPR-clean). Weights 300-700, regular + italic, optical-size axis. -->
  <link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.bunny.net/css?family=newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;0,6..72,500;0,6..72,600;0,6..72,700;1,6..72,300;1,6..72,400;1,6..72,500;1,6..72,600&display=swap"
  />

  <!-- Tailwind via CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            cream:    '#f4efe6',  // hero paper
            paper2:   '#ede6d8',  // alternating sections
            rule:     '#d8cfbe',  // hairlines
            ink:      '#1f1a14',  // near-black warm — headings + dark section bg
            ink2:     '#3a3127',  // softer body text
            muted:    '#8a8175',  // captions, helper text
            accent:   '#7a3a1d',  // deep terracotta
            'accent-light': '#e6a880'  // lighter terracotta for dark section
          },
          fontFamily: {
            serif: ['Newsreader', 'ui-serif', 'Georgia', 'Cambria', 'Times New Roman', 'serif'],
            sans:  ['Newsreader', 'ui-serif', 'Georgia', 'Cambria', 'Times New Roman', 'serif']
          },
          letterSpacing: {
            'editorial-eyebrow': '0.22em',
            'editorial-mono': '0.18em'
          }
        }
      }
    }
  </script>

  <!-- Tally embed (popup form) -->
  <script async src="https://tally.so/widgets/embed.js"></script>

  <style>
    html { scroll-behavior: smooth; }
    body {
      font-optical-sizing: auto;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    /* Optical-size hints per heading scale */
    .opsz-display { font-variation-settings: "opsz" 72; }
    .opsz-md      { font-variation-settings: "opsz" 36; }
    .opsz-sm      { font-variation-settings: "opsz" 18; }

    [data-tally-open] { cursor: pointer; }

    /* FAQ accordion via native <details>/<summary> */
    details > summary {
      list-style: none;
      cursor: pointer;
    }
    details > summary::-webkit-details-marker { display: none; }
    .acc-icon::before { content: '+'; display: inline-block; transition: transform 0.2s ease; }
    details[open] .acc-icon::before { content: '–'; }

    /* Language dropdown caret */
    .lang-caret { display: inline-block; transition: transform 0.2s ease; }
    details.lang-switch[open] .lang-caret { transform: rotate(180deg); }

    /* Soft fade-in on scroll for editorial sections */
    @media (prefers-reduced-motion: no-preference) {
      .reveal { opacity: 0; transform: translateY(8px); transition: opacity 0.6s ease, transform 0.6s ease; }
      .reveal.visible { opacity: 1; transform: none; }
    }

    /* Hero tree — external SVG silhouette. The SVG paints its canvas in our
       page cream (#f4efe6), with the tree itself drawn in a 6-shade terracotta
       gradient (deepest #6b2e15, lightest #b46844). Background-color fallback
       is also cream so a load failure doesn't leave a coloured rectangle.
       Responsive sizing: full presence on desktop, scaled down on smaller
       screens so the city strip and other content stay visible. */
    .hero-tree-bg {
      position: absolute;
      top: 0;
      right: 0;
      width: 60vw;
      height: 70%;
      background-color: #f4efe6;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }
    @media (min-width: 640px) {
      .hero-tree-bg {
        width: 60vw;
        height: 88%;
      }
    }
    @media (min-width: 1024px) {
      .hero-tree-bg {
        width: min(60vw, 820px);
        height: 100%;
      }
    }
    .hero-tree-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
      opacity: 0.5;
    }
  </style>
</head>

<body class="bg-cream text-ink font-serif antialiased">

  <!-- ============================================== Header ============================================== -->
  <header class="sticky top-0 z-40 border-b border-rule bg-cream/85 backdrop-blur">
    <div class="max-w-5xl mx-auto px-6 sm:px-10 py-5 flex items-center justify-between gap-4">
      <a href="{% if loc.isDefault %}/{% else %}/{{ loc.code }}/{% endif %}" class="font-serif italic text-2xl text-ink tracking-tight opsz-md">Vesta</a>
      <div class="flex items-center gap-4 sm:gap-6">
        <!-- Language switcher — compact dropdown of the current locale code -->
        <nav aria-label="Language">
          <details class="lang-switch relative">
            <summary class="flex items-center gap-1.5 cursor-pointer select-none text-[11px] font-semibold tracking-editorial-eyebrow uppercase text-ink2 hover:text-accent transition" aria-label="Change language">
              {{ loc.code | upper }}
              <span class="lang-caret text-[9px] text-muted">▾</span>
            </summary>
            <div class="absolute right-0 mt-3 min-w-[11rem] bg-cream border border-rule rounded-xl py-1 z-50 shadow-[0_10px_30px_-12px_rgba(31,26,20,0.25)]">
              {%- for l in locales %}
              <a href="{% if l.isDefault %}/{% else %}/{{ l.code }}/{% endif %}" hreflang="{{ l.code }}" lang="{{ l.code }}"
                 class="flex items-center justify-between gap-6 px-4 py-2 font-serif italic text-base transition {% if l.code == loc.code %}text-accent{% else %}text-ink2 hover:text-accent{% endif %}"
                 {% if l.code == loc.code %}aria-current="true"{% endif %}>
                {{ l.label }}
                <span class="text-[10px] not-italic font-semibold tracking-editorial-eyebrow uppercase {% if l.code == loc.code %}text-accent{% else %}text-muted{% endif %}">{{ l.code | upper }}</span>
              </a>
              {%- endfor %}
            </div>
          </details>
        </nav>
        <button
          data-tally-open="kdv0Rd"
          data-tally-layout="modal"
          data-tally-overlay="1"
          data-tally-auto-close="2000"
          data-tally-emoji-text="👋"
          data-tally-emoji-animation="wave"
          class="inline-flex items-center px-5 py-2.5 bg-ink hover:bg-black text-cream text-sm font-medium rounded-full transition tracking-wide">
          {{ loc.t.header.cta }}
        </button>
      </div>
    </div>
  </header>

  <main>

    <!-- ============================================== Hero · № 01 ============================================== -->
    <section class="relative overflow-hidden px-6 sm:px-10 py-24 sm:py-32 border-b border-rule">

      <!-- External tree silhouette SVG sourced and placed in the repo. The SVG
           paints its canvas in cream that exactly matches the page background;
           we put it over a terracotta-painted container so terracotta shows
           through only where the tree-shaped negative space is. -->
      <div class="hero-tree-bg" aria-hidden="true">
        <img src="/tree.svg" alt=""/>
      </div>

      <div class="relative z-10 max-w-3xl mx-auto">

        <p class="text-[11px] sm:text-xs font-semibold tracking-editorial-eyebrow uppercase text-accent mb-7 reveal">
          № 01 &nbsp;·&nbsp; {{ loc.t.hero.eyebrow }}
        </p>

        <h1 class="font-serif opsz-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-ink font-normal leading-[1.04] tracking-tight mb-8 reveal" style="text-wrap: pretty;">
          {{ loc.t.hero.headline | safe }}
        </h1>

        <p class="font-serif text-lg sm:text-xl md:text-2xl text-ink2 leading-relaxed font-light max-w-2xl mb-10 reveal">
          {{ loc.t.hero.subhead | safe }}
        </p>

        <div class="mb-5 reveal">
          <button
            data-tally-open="kdv0Rd"
            data-tally-layout="modal"
            data-tally-overlay="1"
            data-tally-auto-close="2000"
            data-tally-emoji-text="👋"
            data-tally-emoji-animation="wave"
            class="inline-flex items-center gap-3 px-8 py-4 bg-ink hover:bg-black text-cream text-sm sm:text-base font-medium tracking-wide rounded-full transition">
            {{ loc.t.hero.cta }}
            <span class="text-base">→</span>
          </button>
        </div>
        <p class="text-sm text-muted reveal">{{ loc.t.hero.noSpam }}</p>

        <!-- City strip — multi-country reality in three small notes -->
        <div class="mt-20 pt-7 border-t border-rule grid grid-cols-3 gap-4 sm:gap-8 reveal">
          <div>
            <div class="font-serif italic text-base sm:text-lg text-ink opsz-sm">Amsterdam</div>
            <div class="text-[11px] sm:text-xs text-muted tracking-wide mt-1">{{ loc.t.hero.cities.amsterdam }}</div>
          </div>
          <div>
            <div class="font-serif italic text-base sm:text-lg text-ink opsz-sm">Istanbul</div>
            <div class="text-[11px] sm:text-xs text-muted tracking-wide mt-1">{{ loc.t.hero.cities.istanbul }}</div>
          </div>
          <div>
            <div class="font-serif italic text-base sm:text-lg text-ink opsz-sm">London</div>
            <div class="text-[11px] sm:text-xs text-muted tracking-wide mt-1">{{ loc.t.hero.cities.london }}</div>
          </div>
        </div>

      </div>
    </section>

    <!-- ============================================== Mental load · № 02 ============================================== -->
    <section class="px-6 sm:px-10 py-24 sm:py-32 bg-paper2 border-b border-rule">
      <div class="max-w-3xl mx-auto">

        <p class="text-[11px] sm:text-xs font-semibold tracking-editorial-eyebrow uppercase text-accent mb-7 reveal">
          № 02 &nbsp;·&nbsp; {{ loc.t.s2.eyebrow }}
        </p>

        <h2 class="font-serif opsz-md text-3xl sm:text-4xl md:text-5xl text-ink font-normal leading-[1.1] tracking-tight mb-10 reveal" style="text-wrap: pretty;">
          {{ loc.t.s2.heading | safe }}
        </h2>

        <p class="font-serif italic text-lg sm:text-xl text-ink2 leading-relaxed font-light max-w-2xl mb-16 reveal">
          {{ loc.t.s2.intro }}
        </p>

        <!-- Stats: large serif terracotta numerals -->
        <div class="border-t border-rule">
          {%- for stat in loc.t.s2.stats %}
          <div class="grid grid-cols-[auto_1fr] gap-x-6 sm:gap-x-10 gap-y-1 py-7 border-b border-rule reveal">
            <div class="font-serif text-5xl sm:text-6xl md:text-7xl text-accent font-light leading-none tracking-tight">{{ stat.num }}</div>
            <div class="text-sm sm:text-base text-ink2 leading-relaxed font-light self-center max-w-md">
              {{ stat.text | safe }}
            </div>
          </div>
          {%- endfor %}
        </div>

        <p class="font-serif text-base sm:text-lg text-ink2 leading-relaxed font-light mt-14 max-w-2xl reveal">
          {{ loc.t.s2.framing }}
        </p>

        <p class="font-serif italic text-xl sm:text-2xl text-ink leading-relaxed mt-12 max-w-2xl font-light reveal">
          {{ loc.t.s2.capstone }}
        </p>

      </div>
    </section>

    <!-- ============================================== How it works · № 03 ============================================== -->
    <section class="px-6 sm:px-10 py-24 sm:py-32 border-b border-rule">
      <div class="max-w-3xl mx-auto">

        <p class="text-[11px] sm:text-xs font-semibold tracking-editorial-eyebrow uppercase text-accent mb-7 reveal">
          № 03 &nbsp;·&nbsp; {{ loc.t.s3.eyebrow }}
        </p>

        <h2 class="font-serif opsz-md text-3xl sm:text-4xl md:text-5xl text-ink font-normal leading-[1.1] tracking-tight mb-6 reveal" style="text-wrap: pretty;">
          {{ loc.t.s3.heading | safe }}
        </h2>

        <p class="font-serif italic text-lg sm:text-xl text-ink2 leading-relaxed font-light max-w-2xl mb-14 reveal">
          {{ loc.t.s3.subhead }}
        </p>

        <!-- Cards: separated tiles, "You → Vesta → outcome" per moment -->
        <div class="grid sm:grid-cols-2 gap-5 sm:gap-6 reveal">

          {%- for card in loc.t.s3.cards %}
          <article class="border border-rule rounded-2xl p-7 sm:p-8">
            <h3 class="font-serif text-2xl text-ink font-normal leading-snug tracking-tight mb-6">{{ card.title }}</h3>
            <div class="space-y-4">
              <div class="grid grid-cols-[3.75rem_1fr] gap-x-3 items-baseline">
                <span class="text-[10px] font-semibold tracking-editorial-eyebrow uppercase text-muted">{{ loc.t.s3.youLabel }}</span>
                <span class="text-sm sm:text-base text-ink2 leading-relaxed font-light">{{ card.you | safe }}</span>
              </div>
              <div class="grid grid-cols-[3.75rem_1fr] gap-x-3 items-baseline">
                <span class="text-[10px] font-semibold tracking-editorial-eyebrow uppercase text-accent">Vesta</span>
                <span class="text-sm sm:text-base text-ink2 leading-relaxed font-light">{{ card.vesta | safe }}</span>
              </div>
            </div>
            <p class="font-serif italic text-base text-ink leading-relaxed font-light mt-6 pt-5 border-t border-rule">
              {{ card.outcome }}
            </p>
          </article>
          {%- endfor %}

        </div>

      </div>
    </section>

    <!-- ============================================== Principles · № 04 ============================================== -->
    <section class="px-6 sm:px-10 py-24 sm:py-32 bg-paper2 border-b border-rule">
      <div class="max-w-3xl mx-auto">

        <p class="text-[11px] sm:text-xs font-semibold tracking-editorial-eyebrow uppercase text-accent mb-7 reveal">
          № 04 &nbsp;·&nbsp; {{ loc.t.s4.eyebrow }}
        </p>

        <h2 class="font-serif opsz-md text-3xl sm:text-4xl md:text-5xl text-ink font-normal leading-[1.1] tracking-tight mb-16 reveal" style="text-wrap: pretty;">
          {{ loc.t.s4.heading | safe }}
        </h2>

        {%- for p in loc.t.s4.principles %}
        <article class="grid grid-cols-[auto_1fr] gap-x-5 sm:gap-x-8 py-10 border-t {% if loop.last %}border-b {% endif %}border-rule reveal">
          <div class="font-serif italic text-2xl sm:text-3xl text-accent font-light leading-none opsz-sm">0{{ loop.index }}.</div>
          <div>
            <h3 class="font-serif text-2xl sm:text-3xl text-ink font-normal leading-snug tracking-tight mb-4">{{ p.title }}</h3>
            <p class="font-serif text-base sm:text-lg text-ink leading-relaxed font-light mb-4">
              {{ p.benefit }}
            </p>
            <blockquote class="border-l-2 border-accent pl-5 py-1 font-serif italic text-base sm:text-lg text-ink2 leading-relaxed font-light">
              {{ p.brief | safe }}
            </blockquote>
          </div>
        </article>
        {%- endfor %}

      </div>
    </section>

    <!-- ============================================== Multi-country · № 05 (DARK) ============================================== -->
    <section class="px-6 sm:px-10 py-24 sm:py-32 bg-ink text-cream">
      <div class="max-w-3xl mx-auto">

        <p class="text-[11px] sm:text-xs font-semibold tracking-editorial-eyebrow uppercase text-accent-light mb-7 reveal">
          № 05 &nbsp;·&nbsp; {{ loc.t.s5.eyebrow }}
        </p>

        <h2 class="font-serif opsz-md text-3xl sm:text-4xl md:text-5xl text-cream font-normal leading-[1.08] tracking-tight mb-12 reveal" style="text-wrap: pretty;">
          {{ loc.t.s5.heading | safe }}
        </h2>

        <!-- Shapes — small mono-styled numbers + italic serif reality -->
        <div class="border-t border-cream/15">

          {%- for shape in loc.t.s5.shapes %}
          <div class="grid grid-cols-[auto_1fr] gap-x-5 sm:gap-x-8 py-5 sm:py-6 border-b border-cream/15 reveal items-baseline">
            <div class="font-serif text-xs sm:text-sm text-accent-light tracking-editorial-mono pt-1">0{{ loop.index }}</div>
            <div class="font-serif italic text-lg sm:text-xl text-cream leading-snug font-light">
              {{ shape | safe }}
            </div>
          </div>
          {%- endfor %}

        </div>

        <!-- 3-degree social graph callout -->
        <div class="mt-12 pb-2 reveal">
          <p class="text-[11px] sm:text-xs font-semibold tracking-editorial-eyebrow uppercase text-accent-light mb-4">
            {{ loc.t.s5.graphEyebrow }}
          </p>
          <p class="font-serif text-lg sm:text-xl text-cream/95 leading-relaxed font-light max-w-2xl">
            {{ loc.t.s5.graphBody }}
          </p>
        </div>

      </div>
    </section>

    <!-- ============================================== Trust · № 06 ============================================== -->
    <section class="px-6 sm:px-10 py-24 sm:py-32 border-b border-rule">
      <div class="max-w-3xl mx-auto">

        <p class="text-[11px] sm:text-xs font-semibold tracking-editorial-eyebrow uppercase text-accent mb-7 reveal">
          № 06 &nbsp;·&nbsp; {{ loc.t.s6.eyebrow }}
        </p>

        <h2 class="font-serif opsz-md text-3xl sm:text-4xl md:text-5xl text-ink font-normal leading-[1.1] tracking-tight mb-6 reveal" style="text-wrap: pretty;">
          {{ loc.t.s6.heading | safe }}
        </h2>

        <p class="font-serif italic text-lg sm:text-xl text-ink2 leading-relaxed font-light max-w-2xl mb-12 reveal">
          {{ loc.t.s6.subline }}
        </p>

        <div class="border-t border-rule">
          {%- for item in loc.t.s6.items %}
          <div class="grid grid-cols-[auto_1fr] gap-x-5 sm:gap-x-8 py-6 border-b border-rule reveal">
            <div class="font-serif text-xs sm:text-sm text-muted tracking-editorial-mono pt-1.5">0{{ loop.index }}</div>
            <div>
              <div class="font-serif italic text-lg sm:text-xl text-ink leading-snug">{{ item.term }}</div>
              <div class="text-sm sm:text-base text-ink2 leading-relaxed font-light mt-1.5">{{ item.desc }}</div>
            </div>
          </div>
          {%- endfor %}
        </div>

      </div>
    </section>

    <!-- ============================================== CTA · № 07 ============================================== -->
    <section class="px-6 sm:px-10 py-24 sm:py-32 bg-paper2 border-b border-rule">
      <div class="max-w-2xl mx-auto text-center">

        <p class="text-[11px] sm:text-xs font-semibold tracking-editorial-eyebrow uppercase text-accent mb-7 reveal">
          № 07 &nbsp;·&nbsp; {{ loc.t.cta.eyebrow }}
        </p>

        <h2 class="font-serif opsz-md text-4xl sm:text-5xl md:text-6xl text-ink font-normal leading-[1.05] tracking-tight mb-6 reveal" style="text-wrap: pretty;">
          {{ loc.t.cta.heading | safe }}
        </h2>

        <p class="font-serif italic text-lg sm:text-xl text-ink2 leading-relaxed font-light mb-10 reveal">
          {{ loc.t.cta.body }}
        </p>

        <button
          data-tally-open="kdv0Rd"
          data-tally-layout="modal"
          data-tally-overlay="1"
          data-tally-auto-close="2000"
          data-tally-emoji-text="👋"
          data-tally-emoji-animation="wave"
          class="inline-flex items-center gap-3 px-8 py-4 bg-ink hover:bg-black text-cream text-sm sm:text-base font-medium tracking-wide rounded-full transition reveal">
          {{ loc.t.cta.button }}
          <span class="text-base">→</span>
        </button>

      </div>
    </section>

    <!-- ============================================== FAQ · № 08 ============================================== -->
    <section class="px-6 sm:px-10 py-24 sm:py-32">
      <div class="max-w-3xl mx-auto">

        <p class="text-[11px] sm:text-xs font-semibold tracking-editorial-eyebrow uppercase text-accent mb-7 reveal">
          № 08 &nbsp;·&nbsp; {{ loc.t.faq.eyebrow }}
        </p>

        <h2 class="font-serif opsz-md text-3xl sm:text-4xl md:text-5xl text-ink font-normal leading-[1.1] tracking-tight mb-12 reveal" style="text-wrap: pretty;">
          {{ loc.t.faq.heading | safe }}
        </h2>

        <div class="border-t border-rule">

          {%- for item in loc.t.faq.items %}
          <details {% if loop.first %}open {% endif %}class="border-b border-rule reveal">
            <summary class="flex justify-between items-start gap-4 py-6">
              <span class="font-serif text-lg sm:text-xl text-ink font-normal leading-snug">{{ item.q | safe }}</span>
              <span class="acc-icon font-serif text-2xl text-accent leading-none pt-1 select-none"></span>
            </summary>
            <p class="text-sm sm:text-base text-ink2 leading-relaxed font-light pb-6 pr-8">
              {{ item.a | safe }}
            </p>
          </details>
          {%- endfor %}

        </div>

      </div>
    </section>

  </main>

  <!-- ============================================== Footer ============================================== -->
  <footer class="px-6 sm:px-10 py-14 bg-paper2 border-t border-rule">
    <div class="max-w-3xl mx-auto flex flex-col sm:flex-row sm:justify-between sm:items-baseline gap-6">
      <p class="font-serif italic text-base sm:text-lg text-ink2 leading-relaxed max-w-md">
        {{ loc.t.footer.tagline }}
      </p>
      <div class="text-xs sm:text-sm text-muted text-left sm:text-right space-y-1.5">
        <div><a href="mailto:hello@vesta.social" class="hover:text-accent transition">hello@vesta.social</a></div>
        <div>{{ loc.t.footer.builtIn }}</div>
      </div>
    </div>
  </footer>

  <!-- Scroll-reveal: progressive enhancement; no-JS users see content normally -->
  <script>
    (function () {
      if (!('IntersectionObserver' in window)) {
        document.querySelectorAll('.reveal').forEach(function (el) { el.classList.add('visible'); });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.reveal').forEach(function (el) { io.observe(el); });
    })();
  </script>

  <!-- Close the language dropdown on outside-click or Escape -->
  <script>
    (function () {
      function closeAll(except) {
        document.querySelectorAll('details.lang-switch[open]').forEach(function (d) {
          if (d !== except) d.removeAttribute('open');
        });
      }
      document.addEventListener('click', function (e) {
        var open = e.target.closest && e.target.closest('details.lang-switch[open]');
        closeAll(open);
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeAll(null);
      });
    })();
  </script>

</body>
</html>
